# Конфигурация Shop-bot
# Скопируйте этот файл в .env и заполните своими значениями

# Обязательные параметры
BOT_TOKEN=your_bot_token_here

# Опциональные параметры для продакшена
PROJECT_NAME=your-project-name
RAILWAY_PUBLIC_DOMAIN=your-railway-domain.railway.app
WEBHOOK_PATH=/webhook

# Администраторы (ID через запятую)
ADMINS=123456789,987654321

# Пример получения ID пользователя:
# 1. Напишите @getmyid_bot в Telegram
# 2. Скопируйте ваш ID
# 3. Вставьте в переменную ADMINS
